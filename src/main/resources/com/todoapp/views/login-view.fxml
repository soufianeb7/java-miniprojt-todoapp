<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.todoapp.controllers.LoginController"
      prefWidth="420" prefHeight="520"
      alignment="CENTER" spacing="0"
      stylesheets="@../css/style.css"
      styleClass="auth-root">

    <!-- Logo / Title area -->
    <VBox alignment="CENTER" spacing="6" styleClass="auth-header">
        <padding><Insets top="40" bottom="30"/></padding>
        <Label text="📋" style="-fx-font-size: 48px;"/>
        <Label text="To-Do List Manager" styleClass="auth-app-title"/>
        <Label text="Sign in to your account" styleClass="auth-subtitle"/>
    </VBox>

    <!-- Login card -->
    <VBox styleClass="auth-card" spacing="14" alignment="CENTER">
        <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

        <Label text="Username" styleClass="form-label" maxWidth="340"/>
        <TextField fx:id="txtUsername" promptText="Enter your username"
                   styleClass="auth-field" maxWidth="340"/>

        <Label text="Password" styleClass="form-label" maxWidth="340"/>
        <PasswordField fx:id="txtPassword" promptText="Enter your password"
                       styleClass="auth-field" maxWidth="340"/>

        <Label fx:id="lblError" text="" styleClass="auth-error"
               maxWidth="340" wrapText="true"/>

        <Button text="Login" onAction="#handleLogin"
                styleClass="btn-primary auth-btn" maxWidth="340"/>

        <Separator maxWidth="340"/>

        <HBox alignment="CENTER" spacing="6">
            <Label text="No account yet?" styleClass="auth-link-text"/>
            <Button text="Register here" onAction="#handleGoToRegister"
                    styleClass="btn-link"/>
        </HBox>
    </VBox>

</VBox>